    {
        "id": "check-alerta-lum",
        "type": "function",
        "z": "tab-1",
        "name": "Verificar Alerta Lum",
        "func": "var lum = parseFloat(msg.payload);\nif (lum < 200) {\n    msg.payload = 'Ambiente muito escuro: ' + lum;\n} else if (lum > 3000) {\n    msg.payload = 'Luminosidade muito alta: ' + lum;\n} else {\n    msg.payload = 'Luminosidade normal: ' + lum;\n}\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 580,
        "y": 280,
        "wires": [
            [
                "ui-text-alerta-lum"
            ]
        ]
    },
    {
        "id": "mysql-insert",
        "type": "function",
        "z": "tab-1",
        "name": "Preparar SQL",
        "func": "var sensor = msg.topic;\nvar valor = Number(msg.payload);\n\nmsg.query = \"INSERT INTO LEITURAS (SENSOR, VALOR, MOMENTO) VALUES (:SENSOR, :VALOR, SYSDATE)\";\n\nmsg.payload = {\n    SENSOR: sensor,\n    VALOR: valor\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 580,
        "y": 380,
        "wires": [
            [
                "99b7066a7eb47e45"
            ]
        ]
    },
