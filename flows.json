                "gauge-temp",
                "chart-temp",
                "check-alerta-temp",
                "mysql-insert"
            ]
        ]
    },
    {
        "id": "check-alerta-temp",
        "type": "function",
        "z": "tab-1",
        "name": "Verificar Alerta Temp",
        "func": "var temp = parseFloat(msg.payload);\nif (temp > 35) {\n    msg.payload = 'ALERTA: Temperatura alta! ' + temp + '°C';\n    msg.color = 'red';\n} else {\n    msg.payload = 'Temperatura normal: ' + temp + '°C';\n    msg.color = 'green';\n}\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 580,
        "y": 140,
        "wires": [
            [
                "ui-text-alerta-temp"
            ]
        ]
    },
