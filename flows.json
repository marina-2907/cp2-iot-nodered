    {
        "id": "http-clima",
        "type": "http request",
        "z": "tab-1",
        "name": "API OpenWeather",
        "method": "GET",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "https://api.openweathermap.org/data/2.5/weather?q=Sao+Paulo,BR&appid=35c299e032a62c4494f13c078a2169ea&units=metric&lang=pt_br",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
        "headers": [],
        "x": 380,
        "y": 500,
        "wires": [
            [
                "parse-clima"
            ]
        ]
    },
    {
        "id": "parse-clima",
        "type": "function",
        "z": "tab-1",
        "name": "Parsear Clima",
        "func": "var data = msg.payload;\nvar temp = data.main.temp;\nvar umidade = data.main.humidity;\nvar descricao = data.weather[0].description;\nvar cidade = data.name;\n\nmsg.payload = {\n    temperatura_ext: temp,\n    umidade_ext: umidade,\n    descricao: descricao,\n    cidade: cidade\n};\n\nmsg.clima_texto = ' ' + cidade + ': ' + temp + '°C, ' + umidade + '% umidade - ' + descricao;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 580,
        "y": 500,
        "wires": [
            [
                "ui-text-clima",
                "gauge-temp-ext",
                "gauge-umid-ext"
            ]
        ]
    },
