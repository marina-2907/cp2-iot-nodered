    {
        "id": "parse-temp",
        "type": "function",
        "z": "tab-1",
        "name": "Parsear Temperatura",
        "func": "var valor = parseFloat(msg.payload);\nmsg.payload = valor;\nmsg.topic = \"temperatura\";\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 80,
        "wires": [
